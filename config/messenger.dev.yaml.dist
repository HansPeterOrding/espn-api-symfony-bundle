framework:
    messenger:
        transports:
            sync.espn-season:
                dsn: '%env(MESSENGER_TRANSPORT_DSN)%'
                options:
                    queue_name: 'sync.espn-season'
                retry_strategy:
                    max_retries: 1000
                    delay: 1000
                    max_delay: 0
                    jitter: 0.1

